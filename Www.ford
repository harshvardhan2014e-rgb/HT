<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ford.com</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Custom CSS -->
  <link rel="stylesheet" href="style.css">
</head>
<body data-bs-spy="scroll" data-bs-target="#navbar" data-bs-offset="50" tabindex="0"> 
    

  <!-- Navbar -->
  <nav id="navbar" class="navbar navbar-expand-lg navbar-primary bg-primary fixed-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="#"><img src="Ford_logo-removebg-preview.png" width="200" height="100"></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="#about">Cars</a></li>
          <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
          <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Home Section with Carousel -->
  <section id="home" class="pt-5 mt-5">
    <div id="portfolioCarousel" class="carousel slide" data-bs-ride="carousel">
      <div class="carousel-inner">
        <div class="carousel-item active">
          <img src="BG1.png" class="d-block w-100" alt="Project 1">
        </div>
        <div class="carousel-item">
          <img src="BG@.png" class="d-block w-100" alt="Project 2">
        </div>
    
        </div>
      </div>
      <button class="carousel-control-prev" type="button" data-bs-target="#portfolioCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#portfolioCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
      </button>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="pt-5">
    <div class="container">
      <img src="b" alt=""><h2>Ford</h2>
      
      
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="pt-5 bg-light">
    <div class="container">
      <h2>Services</h2>
      <ul>
        
        <li>HTML</li>
        <li>Bootstrap </li>
        <li>CSS</li>
      </ul>
    </div>
  </section>

  

  <!-- Contact Section -->
  <section id="contact" class="pt-5">
    <div class="container">
      <h2>Contact</h2>
      <p>Email: Harshvardhan2014.e@gmail.com</p>
      <p>Phone: +91 1234567890</p>
    </div>
  </section>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  
</body>
</html>