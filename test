<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auron India</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0A1A3C;
      color: #fff;
    }
    nav {
      position: fixed;
      top: 0;
      width: 100%;
      background: #111;
      padding: 15px;
      display: flex;
      justify-content: center;
      z-index: 1000;
    }
    nav a {
      color: #FFD700;
      text-decoration: none;
      margin: 0 15px;
      font-weight: bold;
    }
    section {
      min-height: 100vh;
      padding: 80px 20px;
      text-align: center;
    }
    .hero {
      background: url('car-banner.jpg') no-repeat center center/cover;
      display: flex;
      flex-direction: column;
      justify-content: center;
      color: #fff;
    }
    .hero h1 {
      font-size: 3em;
      margin: 0;
    }
    .hero p {
      font-size: 1.2em;
    }
    .cars {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-top: 40px;
    }
    .car-card {
      background: #1a1a1a;
      border-radius: 8px;
      padding: 20px;
      transition: transform 0.3s;
    }
    .car-card:hover {
      transform: scale(1.05);
    }
    .car-card img {
      width: 100%;
      border-radius: 6px;
    }
    .car-card h3 {
      margin: 15px 0 5px;
      color: #FFD700;
    }
    .car-card p {
      font-size: 0.9em;
      color: #ccc;
    }
    footer {
      background: #111;
      padding: 20px;
      text-align: center;
      color: #aaa;
    }
  </style>
</head>
<body>

  <nav>
    <a href="#hero">Home</a>
    <a href="#about">About Us</a>
    <a href="#models">Models</a>
    <a href="#leadership">Leadership</a>
    <a href="#contact">Contact</a>
  </nav>

  <section id="hero" class="hero">
    <h1>Auron India</h1>
    <p>Driving innovation in investment, strategy, and growth.</p>
  </section>

  <section id="about">
    <h2>About Us</h2>
    <p>Auron India is a trusted leader in investment banking, asset management, private equity, and wealth advisory. We deliver long‑term value through strategy, trust, and growth.</p>
  </section>

  <section id="models">
    <h2>Our Models</h2>
    <div class="cars">
      <div class="car-card">
        <img src="suv.jpg" alt="SUV">
        <h3>Urban SUV</h3>
        <p>Compact, stylish, and city‑friendly.</p>
      </div>
      <div class="car-card">
        <img src="ev.jpg" alt="Electric Car">
        <h3>Electric Vision</h3>
        <p>Smart, sustainable, and future‑ready.</p>
      </div>
      <div class="car-card">
        <img src="luxury.jpg" alt="Luxury Car">
        <h3>Luxury Sedan</h3>
        <p>Elegance meets performance.</p>
      </div>
    </div>
  </section>

  <section id="leadership" class="leadership">
    <h2>Leadership</h2>
    <p>Meet the visionary leaders who guide Auron India with expertise, integrity, and innovation.</p>
    <a href="#hero" class="close-btn">Close</a>
  </section>

  <section id="contact">
    <h2>Contact Us</h2>
    <p>Email: info@auronindia.com | Phone: +91 1234567890</p>
  </section>

  <footer>
    <p>&copy; 2026 Auron India. All rights reserved.</p>
  </footer>

</body>
</html>
