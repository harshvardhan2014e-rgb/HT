<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Bootstrap demo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</head>

<style>
    body {
        overflow-x: hidden;
    }

    /* Horizontal scroll container */
    .scrollspy-horizontal {
        display: flex;
        overflow-x: auto;
        scroll-behavior: smooth;
        height: 100vh;
    }

    /* Sections */
    .section {
        min-width: 100vw;
        height: 100vh;
        padding: 80px 20px;
        flex-shrink: 0;
    }

    #scrollspyHeading1 {
        background: orange;
        color: white;
    }

    #scrollspyHeading2 {
        background: lightblue;
    }

    #scrollspyHeading3 {
        background: lightgreen;
    }

    #scrollspyHeading4 {
        background: lightcoral;
    }

    #scrollspyHeading5 {
        background: lightgray;
    }
</style>
</head>

<body>

    <!-- Navbar -->
    <nav id="navbar-example2" class="navbar bg-dark px-3 mb-0 fixed-top">
        <a class="navbar-brand text-white" href="#">Navbar</a>

        <ul class="nav nav-pills">
            <li class="nav-item">
                <a class="nav-link active" href="#scrollspyHeading1">First</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#scrollspyHeading2">Second</a>
            </li>
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#">Dropdown</a>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#scrollspyHeading3">Third</a></li>
                    <li><a class="dropdown-item" href="#scrollspyHeading4">Fourth</a></li>
                    <li>
                        <hr class="dropdown-divider">
                    </li>
                    <li><a class="dropdown-item" href="#scrollspyHeading5">Fifth</a></li>
                </ul>
            </li>
        </ul>
    </nav>

    <!-- Horizontal Sections -->
    <div class="scrollspy-horizontal" id="scrollContainer">

        <div id="scrollspyHeading1" class="section">
            <h1>First</h1>
        </div>

        <div id="scrollspyHeading2" class="section">
            <h1>Second</h1>
        </div>

        <div id="scrollspyHeading3" class="section">
            <h1>Third</h1>
        </div>

        <div id="scrollspyHeading4" class="section">
            <h1>Fourth</h1>
        </div>

        <div id="scrollspyHeading5" class="section">
            <h1>Fifth</h1>
        </div>

    </div>

    <script>
        const container = document.getElementById("scrollContainer");
        const links = document.querySelectorAll(".nav-link, .dropdown-item");

        // Click → horizontal scroll
        links.forEach(link => {
            link.addEventListener("click", function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute("href"));
                container.scrollTo({
                    left: target.offsetLeft,
                    behavior: "smooth"
                });
            });
        });

        // Active link update
        container.addEventListener("scroll", () => {
            let scrollPos = container.scrollLeft;

            document.querySelectorAll(".section").forEach(section => {
                let offset = section.offsetLeft;
                let width = section.offsetWidth;

                if (scrollPos >= offset - 50 && scrollPos < offset + width) {
                    let id = section.getAttribute("id");

                    document.querySelectorAll(".nav-link").forEach(l => l.classList.remove("active"));
                    document.querySelectorAll(".dropdown-item").forEach(l => l.classList.remove("active"));

                    let activeLink = document.querySelector(`[href="#${id}"]`);
                    if (activeLink) activeLink.classList.add("active");
                }
            });
        });
    </script>

</body>

</html>


</body>
</html>

