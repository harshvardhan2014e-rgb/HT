<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>My Company</title>
    <link rel="stylesheet" href="style.css">
    <style>
        /* Background color for the whole site */
body {
font-family: Arial, sans-serif;
margin: 0;
background: #e6f2ff; /* Light blue background */
}

/* Header styling */
header {
background: #0066cc;
color: white;
padding: 30px;
text-align: center;
}

/* Navigation bar styling */
nav {
background: #333;
text-align: center;
padding: 10px;
}
nav a {
color: white;
margin: 0 15px;
text-decoration: none;
font-weight: bold;
}
nav a:hover {
color: #ffcc00; /* Highlight on hover */
}

/* Section styling */
section {
padding: 40px;
text-align: center;
}

/* Footer styling */
footer {
background: #222;
color: #ccc;
text-align: center;
padding: 20px;
} </style>
</head>

<body>
    <header>
        <h1>AURON INDIA</h1>
        <p>Innovating for a brighter future</p>
    </header>

    <!-- Navigation bar with more buttons -->
    <nav>
        <a href="#about">About Us</a>
        <a href="#leadership">Leadership</a>
        <a href="#services">Services</a>
        <a href="#careers">Careers</a>
        <a href="#contact">Contact</a>
    </nav>

    <section id="about">
        <h2>About Us</h2>
        <p>We are a passionate team delivering creative solutions in technology and design.</p>
    </section>

    <section id="leadership">
        <h2>Leadership</h2>
        <p>Meet our leadership team who guide our vision and strategy.</p>
    </section>

    <section id="services">
        <h2>Our Services</h2>
        <ul>
            <li>Web Development</li>
            <li>Digital Art</li>
            <li>Consulting</li>
        </ul>
    </section>

    <section id="careers">
        <h2>Careers</h2>
        <p>Join our team and help us build the future.</p>
    </section>

    <section id="contact">
        <h2>Contact Us</h2>
        <p>Email: info@mycompany.com</p>
        <p>Phone: +91 98765 43210</p>
    </section>

    <footer>
        <p>© 2026 My Company. All rights reserved.</p>
    </footer>
