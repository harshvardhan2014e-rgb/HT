<!DOCTYPE html>
<html>
<head>
  <title>Multiplication Example</title>
</head>
<body>
  <h1>Multiplication Using Functions</h1>

  <p>Enter two numbers:</p>
  <input type="number" id="num1">
  <input type="number" id="num2">
  <button onclick="multiplyNumbers()">Multiply</button>

  <p id="result"></p>

  <script>
    // Simple function for multiplication
    function multiply(a, b) {
      return a * b;
    }

    // Function to get values and show result
    function multiplyNumbers() {
      let x = document.getElementById("num1").value;
      let y = document.getElementById("num2").value;

      let answer = multiply(x, y);

      document.getElementById("result").innerHTML = 
        "Result: " + x + " × " + y + " = " + answer;
    }
  </script>
</body>
</html>
