<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>My Hobbies</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f0f8ff;
            text-align: center;
            padding: 20px;
        }

        h1 {
            color: #2c3e50;
        }

        #hobbyList {
            margin-top: 20px;
            font-size: 18px;
            color: #34495e;
        }

        button {
            margin-top: 15px;
            padding: 10px 20px;
            background: #3498db;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background: #2980b9;
        }
    </style>
</head>

<body>
    <h1>Share My Hobbies</h1>
    <p>Click the button to see what I enjoy doing!</p>

    <div id="hobbyList"></div>
    <button id="showHobbies">Show Hobbies</button>

    <script>
        // Event: Page load
        window.onload = function () {
            console.log("Page has loaded successfully!");
            document.getElementById("hobbyList").textContent = "Welcome! Ready to explore my hobbies?";
        };

        // Event: Button click
        document.getElementById("showHobbies").addEventListener("click", function () {
            const hobbies = ["Coding", "Cricket", "Playing", "Papercraft"];
            document.getElementById("hobbyList").innerHTML = hobbies.map(hobby => "• " + hobby).join("<br>");
        });
    </script>
</body>

</html>

