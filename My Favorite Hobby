<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>My Hobbies</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <!-- Hobby Section -->
    <div class="container my-5">
        <h2 class="text-center mb-4">My Hobbies</h2>

        <div class="row">
            <!-- Art -->
            <div class="col-md-3 text-center p-3 bg-light border rounded">
                <img src="Art.png" alt="Art icon" class="img-fluid mb-2" style="height:80px;">
                <h4 class="text-warning">Art</h4>
                <p>I love painting and sketching.</p>
            </div>

            <!-- Reading -->
            <div class="col-md-3 text-center p-3 bg-light border rounded">
                <img src="Reading.png" alt="Reading icon" class="img-fluid mb-2" style="height:80px;">
                <h4 class="text-primary">Reading</h4>
                <p>Books open up new worlds for me.</p>
            </div>

            <!-- Gardening -->
            <div class="col-md-3 text-center p-3 bg-light border rounded">
                <img src="Gardening.png" alt="Gardening icon" class="img-fluid mb-2" style="height:80px;">
                <h4 class="text-success">Gardening</h4>
                <p>Taking care of plants keeps me relaxed.</p>
            </div>

            <!-- Photography -->
            <div class="col-md-3 text-center p-3 bg-light border rounded">
                <img src="phote.png" alt="Photography icon" class="img-fluid mb-2" style="height:80px;">
                <h4 class="text-danger">Photography</h4>
                <p>Capturing moments is my passion.</p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>